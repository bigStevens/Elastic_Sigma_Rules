{"id": "d7fb8f0e-bd5f-45c2-b467-19571c490d7e", "name": "SIGMA - Cleartext Protocol Usage", "enabled": true, "throttle": "no_actions", "interval": "5m", "author": ["Alexandr Yampolskyi, SOC Prime, Tim Shelton"], "description": "Ensure that all account usernames and authentication credentials are transmitted across networks using encrypted channels.\nEnsure that an encryption is used for all sensitive information in transit. Ensure that an encrypted channels is used for all administrative account access.\n", "rule_id": "d7fb8f0e-bd5f-45c2-b467-19571c490d7e", "false_positives": ["Unknown"], "from": "now-5m", "immutable": false, "license": "DRL", "output_index": "", "meta": {"from": "1m"}, "max_signals": 100, "risk_score": 21, "severity": "low", "risk_score_mapping": [], "severity_mapping": [], "threat": [], "tags": ["attack-credential-access"], "to": "now", "references": ["https://www.cisecurity.org/controls/cis-controls-list/", "https://www.pcisecuritystandards.org/documents/PCI_DSS_v3-2-1.pdf", "https://nvlpubs.nist.gov/nistpubs/CSWP/NIST.CSWP.04162018.pdf"], "version": 1, "exceptions_list": [], "related_integrations": [], "required_fields": [], "setup": "", "type": "eql", "language": "eql", "index": ["apm-*-transaction*", "auditbeat-*", "endgame-*", "filebeat-*", "logs-*", "packetbeat-*", "traces-apm*", "winlogbeat-*", "-*elastic-cloud-logs-*"], "query": "any where (dst_port like~ (8080, 21, 80, 23, 50000, 1521, 27017, 3306, 1433, 11211, 15672, 5900, 5901, 5902, 5903, 5904)) and ((action like~ (\"forward\", \"accept\", 2)) or blocked:\"false\")", "filters": [], "actions": []}
